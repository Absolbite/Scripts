local function GetTableLength(tbl)
    if tbl["n"] then return tbl.n end
    local n = 0
    for _ in pairs(tbl) do n += 1 end
    return n
end

local function JoinTable(tbl, prefix, suffix)
    local s = ""
    for _, v in pairs(tbl) do
        s ..= prefix .. tostring(v) .. suffix
    end
    return string.sub(s, 1, #s - #suffix)
end

