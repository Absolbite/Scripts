local function IsPlayerModule(origin, instance)
    if instance and instance.ClassName ~= "BindableEvent" then return false end
    if not origin or typeof(origin) ~= "Instance" or not origin:IsA("LuaSourceContainer") then return false end
    local pm = origin:FindFirstAncestor("PlayerModule")
    if not pm then return false end
    if pm.Parent == nil then return true end
    if PlayerScripts then return compareinstances and compareinstances(pm.Parent, PlayerScripts) or pm.Parent == PlayerScripts end
    return false
end

local function ShouldIgnore(instance, origin)
    if realconfigs.ignoredClasses[instance.ClassName] == true then return true end
    if realconfigs.ignorePlayerModule and IsPlayerModule(origin, instance) then return true end
    return false
end

local Hooks = {}

local function HookFunction(target, replacement)
    if oth and oth.hook then
        return oth.hook(target, replacement)
    elseif hookfunction then
        return hookfunction(target, replacement)
    else
        warn("[RemoteSpy] hookfunction not available!")
    end
end

local function RestoreFunction(fn, silent)
    local original = Hooks[fn]
    if silent and not original then return end
    assert(original, "[RemoteSpy] Function not hooked")

    if oth and oth.unhook then
        pcall(oth.unhook, fn)
    elseif restorefunction and isfunctionhooked and isfunctionhooked(fn) then
        restorefunction(fn)
    elseif hookfunction then
        hookfunction(fn, original)
    end
    Hooks[fn] = nil
end

