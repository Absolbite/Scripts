local function shutdown()
    if schedulerconn then schedulerconn:Disconnect() end

    for _, conn in pairs(connections) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
    end

    for _, t in next, running_threads do
        if coroutine.status(t) ~= "dead" then
            pcall(coroutine.close, t)
        end
    end

    clear(running_threads)
    clear(connections)
    clear(logs)
    clear(remoteLogs)

    disablehooks()

    SimpleSpy3:Destroy()
    Storage:Destroy()

    UserInputService.MouseIconEnabled = true
    getgenv().SimpleSpyExecuted = false
    getgenv().SimpleSpyShutdown = nil
end

if not getgenv().SimpleSpyExecuted then
    local ok, err = pcall(function()
        if not RunService:IsClient() then
            error("RemoteSpy cannot run on the server!")
        end

        getgenv().SimpleSpyShutdown = shutdown

        onToggleClick()

        codebox = Highlight.new(CodeBox)

        logthread(spawn(function()
            local suc, result = pcall(game.HttpGet, game, "https://raw.githubusercontent.com/infyiff/backup/refs/heads/main/SimpleSpyV3/update.txt")
            if codebox then codebox:setRaw((suc and result) or "-- RemoteSpy (Improved, Cobalt-inspired)") end
        end))

        TooltipLabel:GetPropertyChangedSignal("Text"):Connect(scaleToolTip)

        MinimizeButton.MouseButton1Click:Connect(toggleMinimize)
        MaximizeButton.MouseButton1Click:Connect(toggleSideTray)
        ToggleBtn.MouseButton1Click:Connect(onToggleClick)
        ToggleBtn.MouseEnter:Connect(onToggleHover)
        ToggleBtn.MouseLeave:Connect(onToggleUnhover)
        CloseButton.MouseEnter:Connect(function()
            TweenService:Create(CloseButton, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(255, 60, 60) }):Play()
        end)
        CloseButton.MouseLeave:Connect(function()
            TweenService:Create(CloseButton, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(37, 36, 38) }):Play()
        end)
        CloseButton.MouseButton1Click:Connect(shutdown)

        Background.MouseEnter:Connect(function() mouseInGui = true end)
        Background.MouseLeave:Connect(function() mouseInGui = false end)

        TrackConnection(UserInputService.InputBegan:Connect(backgroundUserInput))

        local function connectResize()
            if not workspace.CurrentCamera then
                workspace:GetPropertyChangedSignal("CurrentCamera"):Wait()
            end
            local lastCam = workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(bringBackOnResize)
            workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
                lastCam:Disconnect()
                lastCam = workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(bringBackOnResize)
            end)
        end
        connectResize()

        schedulerconn = RunService.Heartbeat:Connect(taskscheduler)

        logthread(spawn(function()
            local lp = LocalPlayer
            generation = {
                [OldDebugId(lp)]         = 'game:GetService("Players").LocalPlayer',
                [OldDebugId(lp:GetMouse())] = 'game:GetService("Players").LocalPlayer:GetMouse()',
                [OldDebugId(game)]       = "game",
                [OldDebugId(workspace)]  = "workspace",
            }
        end))

        bringBackOnResize()
        SimpleSpy3.Parent = (gethui and gethui()) or CoreGui

        task.delay(1, onToggleUnhover)
    end)

    if ok then
        getgenv().SimpleSpyExecuted = true
    else
        shutdown()
        warn("[RemoteSpy] Init error:", err)
    end
else
    SimpleSpy3:Destroy()
end

