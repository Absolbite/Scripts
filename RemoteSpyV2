local function validateSize()
    local x, y     = Background.AbsoluteSize.X, Background.AbsoluteSize.Y
    local screen   = workspace.CurrentCamera.ViewportSize
    if x + Background.AbsolutePosition.X > screen.X then
        x = math.max(450, screen.X - Background.AbsolutePosition.X)
    end
    if y + Background.AbsolutePosition.Y > screen.Y then
        y = math.max(268, screen.Y - Background.AbsolutePosition.Y)
    end
    Background.Size = UDim2.fromOffset(x, y)
end

local function bringBackOnResize()
    validateSize()
    if sideClosed then minimizeSize() else maximizeSize() end
    local cx       = Background.AbsolutePosition.X
    local cy       = Background.AbsolutePosition.Y
    local viewport = workspace.CurrentCamera.ViewportSize
    cx = math.clamp(cx, 0, viewport.X - (sideClosed and 131 or Background.AbsoluteSize.X))
    cy = math.clamp(cy, 0, viewport.Y - (closed and 19 or Background.AbsoluteSize.Y) - GuiInset.Y)
