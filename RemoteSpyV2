local function formatstr(s)
    s = s:gsub('\\', '\\\\'):gsub('"', '\\"'):gsub('\n', '\\n'):gsub('\t', '\\t')
    return '"' .. s .. '"'
end

local function getplayer(instance)
    for _, v in next, Players:GetPlayers() do
        if v.Character and (instance:IsDescendantOf(v.Character) or instance == v.Character) then
            return v
        end
    end
end

local function i2p(instance)
    if not instance or not instance.Parent then return "nil" end
    local player = getplayer(instance)
    local out = ""
    local parent = instance
    if player then
        while parent do
            if parent == player.Character then
                if player == LocalPlayer then
                    return 'game:GetService("Players").LocalPlayer.Character' .. out
                else
                    return 'game:GetService("Players"):FindFirstChild(' .. formatstr(player.Name) .. ').Character' .. out
                end
            end
            out = (parent.Name:match("^[%a_][%w_]*$") and ("." .. parent.Name) or (':FindFirstChild(' .. formatstr(parent.Name) .. ')')) .. out
            parent = parent.Parent
            task.wait()
        end
    elseif parent ~= game then
        while parent do
            if parent.Parent == game then
                local ok, svc = pcall(function() return cloneref_fn(game:GetService(parent.ClassName)) end)
                if ok and svc then
                    if lower(parent.ClassName) == "workspace" then
                        return "workspace" .. out
                    end
                    return 'game:GetService("' .. parent.ClassName .. '")' .. out
                else
                    return "game." .. parent.Name .. out
                end
            elseif not parent.Parent then
                getNilRequired = true
                return 'getNil(' .. formatstr(parent.Name) .. ', "' .. parent.ClassName .. '")' .. out
            else
                out = (parent.Name:match("^[%a_][%w_]*$") and (':WaitForChild("' .. parent.Name .. '")') or (':WaitForChild(' .. formatstr(parent.Name) .. ')')) .. out
            end
            if instance:IsDescendantOf(LocalPlayer) then
                return 'game:GetService("Players").LocalPlayer' .. out
            end
            parent = parent.Parent
            task.wait()
        end
    else
        return "game"
    end
    return "nil --[[path not found]]"
end

local function genScript(remote, args)
    if type(remote) == "table" then
        -- ReplicatedStorage fake remote
        local gen = "-- ReplicatedStorage interaction: " .. tostring(remote.Name or "?") .. "\n"
        if args and #args > 0 then
            local ok, result = pcall(function() return LazyFix.Convert(args, true) end)
            if ok then gen = gen .. "local args = " .. result .. "\n" end
        end
        return gen
    end

    prevTables = {}
    local gen = ""

    if #args > 0 then
        local ok, result = xpcall(function()
            return "local args = " .. LazyFix.Convert(args, true) .. "\n"
        end, function(err)
            return "-- Serialization error: " .. err .. "\nlocal args = {}\n"
        end)
        gen = result

        if not remote:IsDescendantOf(game) and not getNilRequired then
            gen = 'function getNil(name,class) for _,v in next, getnilinstances() do if v.ClassName==class and v.Name==name then return v end end end\n\n' .. gen
        end

        local path = i2p(remote)
        if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
            gen ..= path .. ":FireServer(table.unpack(args))"
        elseif remote:IsA("RemoteFunction") then
            gen ..= path .. ":InvokeServer(table.unpack(args))"
        end
    else
        local path = i2p(remote)
        if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
            gen ..= path .. ":FireServer()"
        elseif remote:IsA("RemoteFunction") then
            gen ..= path .. ":InvokeServer()"
        end
    end

    prevTables = {}
    return gen
end

