local function remoteHandler(data)
    if configs.autoblock then
        local id = data.id
        if excluding[id] then return end

        if not history[id] then
            history[id] = { badOccurrences = 0, lastCall = tick() }
        end

        local h = history[id]
        if tick() - h.lastCall < 1 then
            h.badOccurrences += 1
            if h.badOccurrences > 3 then
                excluding[id] = true
                return
            end
            return
        else
            h.badOccurrences = 0
        end
        h.lastCall = tick()
    end

    if data.type == "replicated" then
        newRemote("replicated", data)
    elseif data.remote:IsA("RemoteEvent") or data.remote:IsA("UnreliableRemoteEvent") then
        if lower(data.method) == "fireserver" then
            newRemote("event", data)
        end
    elseif data.remote:IsA("RemoteFunction") then
        if lower(data.method) == "invokeserver" then
            newRemote("function", data)
        end
    end
end

local function taskscheduler()
    if not toggle then scheduled = {}; return end
    if #scheduled > (configs.maxRemotes or 300) + 100 then
        table.remove(scheduled, #scheduled)
    end
    if #scheduled > 0 then
        local current = table.remove(scheduled, 1)
        if type(current) == "table" and type(current[1]) == "function" then
            pcall(table.unpack(current))
        end
    end
end

local function schedule(f, ...)
    table.insert(scheduled, { f, ... })
end


local function initRSTracking()
    local ok, RS = pcall(function() return cloneref_fn(game:GetService("ReplicatedStorage")) end)
    if not ok or not RS then return end

    local function registerDesc(desc)
        local ok2, id = pcall(OldDebugId, desc)
        if ok2 then rsKnownIds[id] = true end
    end
    for _, v in next, RS:GetDescendants() do pcall(registerDesc, v) end
    local okRS, rsId = pcall(OldDebugId, RS)
    if okRS then rsKnownIds[rsId] = true end
    RS.DescendantAdded:Connect(function(d) pcall(registerDesc, d) end)
end

local newnamecall = newcclosure_fn(function(...)
    local method = getnamecallmethod()

    if method and toggle and not checkcaller_fn() and typeof(...) == "Instance" then
        local inst = (...)
        local logMethods = {
            FireServer=true, InvokeServer=true, fireServer=true, invokeServer=true,
            Fire=true, Invoke=true, fire=true, invoke=true,
        }
        if logMethods[method] then
            local ok, id = pcall(OldDebugId, inst)
            if ok and rsKnownIds[id] then
                local args   = { select(2, ...) }
                local logid  = id .. "_" .. method
                local now    = tick()
                if not tablecheck(blacklist, inst, logid) and (not rsCallDebounce[logid] or now - rsCallDebounce[logid] > 0.1) then
                    rsCallDebounce[logid] = now
                    local fakeRemote = { Name = "[RS] " .. inst.Name .. ":" .. method, ClassName = inst.ClassName }
                    local data = {
                        type = "replicated",
                        method = method,
                        remote = fakeRemote,
                        args = deepclone(args),
                        id = logid,
                        callingscript = nil,
                        infofunc = nil,
                        metamethod = "__namecall",
                        blockcheck = false,
                        returnvalue = {},
                    }
                    if configs.funcEnabled then
                        local ok2, fi = pcall(info_fn, 2, "f")
                        if ok2 then data.infofunc = fi end
                        local cs = getcallingscript_fn()
                        if type(cs) == "userdata" then data.callingscript = cloneref_fn(cs) end
                    end
                    schedule(remoteHandler, data)
                end
            end
        end
    end

    if method and (method == "FireServer" or method == "fireServer" or method == "InvokeServer" or method == "invokeServer") then
        if typeof(...) == "Instance" then
            local remote = cloneref_fn(...)

            local callingscript = configs.funcEnabled and getcallingscript_fn() or nil
            if ShouldIgnore(remote, callingscript) then
                return originalnamecall(...)
            end

            if (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") or remote:IsA("UnreliableRemoteEvent")) then
                if not configs.logcheckcaller and checkcaller_fn() then
                    return originalnamecall(...)
                end

                local id         = ThreadGetDebugId(remote)
                local blockcheck = tablecheck(blocklist, remote, id)
                local args       = { select(2, ...) }

                if not tablecheck(blacklist, remote, id) and not IsCyclicTable(args) then
                    local data = {
                        method       = method,
                        remote       = remote,
                        args         = deepclone(args),
                        infofunc     = nil,
                        callingscript = nil,
                        metamethod   = "__namecall",
                        blockcheck   = blockcheck,
                        id           = id,
                        returnvalue  = {},
                    }
                    args = nil

                    if configs.funcEnabled then
                        data.infofunc = info_fn(2, "f")
                        local cs = getcallingscript_fn()
                        if type(cs) == "userdata" then
                            data.callingscript = cloneref_fn(cs)
                        end
                    end

                    schedule(remoteHandler, data)
                end

                if blockcheck then return end
            end
        end
    end

    return originalnamecall(...)
end)

local function newindex(method, originalFunction, ...)
    if typeof(...) == "Instance" then
        local remote = cloneref_fn(...)

        local cs = configs.funcEnabled and getcallingscript_fn() or nil
        if ShouldIgnore(remote, cs) then return originalFunction(...) end

        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") or remote:IsA("UnreliableRemoteEvent") then
            if not configs.logcheckcaller and checkcaller_fn() then return originalFunction(...) end

            local id         = ThreadGetDebugId(remote)
            local blockcheck = tablecheck(blocklist, remote, id)
            local args       = { select(2, ...) }

            if not tablecheck(blacklist, remote, id) and not IsCyclicTable(args) then
                local data = {
                    method       = method,
                    remote       = remote,
                    args         = deepclone(args),
                    infofunc     = nil,
                    callingscript = nil,
                    metamethod   = "__index",
                    blockcheck   = blockcheck,
                    id           = id,
                    returnvalue  = {},
                }
                args = nil

                if configs.funcEnabled then
                    data.infofunc = info_fn(2, "f")
                    local calling = getcallingscript_fn()
                    data.callingscript = calling and cloneref_fn(calling) or nil
                end

                schedule(remoteHandler, data)
            end

            if blockcheck then return end
        end
    end
    return originalFunction(...)
end

local newFireServer = newcclosure_fn(function(...) return newindex("FireServer", originalEvent, ...) end)
local newUnreliableFireServer = newcclosure_fn(function(...) return newindex("FireServer", originalUnreliableEvent, ...) end)
local newInvokeServer = newcclosure_fn(function(...) return newindex("InvokeServer", originalFunction, ...) end)

local function disablehooks()
    local gameMT = getrawmeta(game)
    if oth and oth.unhook then
        pcall(oth.unhook, gameMT.__namecall)
        pcall(oth.unhook, originalEvent)
        pcall(oth.unhook, originalFunction)
        pcall(oth.unhook, originalUnreliableEvent)
    elseif restorefunction and isfunctionhooked then
        pcall(restorefunction, gameMT.__namecall)
        pcall(restorefunction, originalEvent)
        pcall(restorefunction, originalFunction)
        pcall(restorefunction, originalUnreliableEvent)
    else
        if hookmetamethod_fn then
            pcall(hookmetamethod_fn, game, "__namecall", originalnamecall)
        elseif hookfunction then
            pcall(hookfunction, gameMT.__namecall, originalnamecall)
        end
        pcall(hookfunction, originalEvent, originalEvent)
        pcall(hookfunction, originalFunction, originalFunction)
        pcall(hookfunction, originalUnreliableEvent, originalUnreliableEvent)
    end
end

local function toggleSpy()
    if not toggle then
        local oldnamecall
        if synv3 and hook then
            oldnamecall               = hook(getrawmeta(game).__namecall, clonefunction_fn(newnamecall))
            originalEvent             = hook(remoteEvent.FireServer,           clonefunction_fn(newFireServer))
            originalFunction          = hook(remoteFunction.InvokeServer,      clonefunction_fn(newInvokeServer))
            originalUnreliableEvent   = hook(unreliableRemoteEvent.FireServer, clonefunction_fn(newUnreliableFireServer))
        else
            if hookmetamethod_fn then
                oldnamecall = hookmetamethod_fn(game, "__namecall", clonefunction_fn(newnamecall))
            elseif hookfunction then
                oldnamecall = hookfunction(getrawmeta(game).__namecall, clonefunction_fn(newnamecall))
            end
            originalEvent           = hookfunction(remoteEvent.FireServer,           clonefunction_fn(newFireServer))
            originalFunction        = hookfunction(remoteFunction.InvokeServer,      clonefunction_fn(newInvokeServer))
            originalUnreliableEvent = hookfunction(unreliableRemoteEvent.FireServer, clonefunction_fn(newUnreliableFireServer))
        end

        if not originalnamecall then
            originalnamecall = function(...) return oldnamecall(...) end
        end
        pcall(initRSTracking)
    else
        disablehooks()
    end
end

local function toggleSpyMethod()
    toggleSpy()
