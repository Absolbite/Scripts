local TRIAL_OPTIONS = {"Trial Easy", "Trial Medium", "Trial Hard"}

local function getTrialFolder(trialName)
    local gm = getGamemodesFolder()
    if not gm then return nil end
    return gm:FindFirstChild(trialName)
end

local function isInTrial(trialName)
    local folder = getTrialFolder(trialName)
    return folder and #folder:GetChildren() > 0
end

local function getCurrentWave(trialName)
    local ok, result = pcall(function()
        return game:GetService("Players").LocalPlayer.PlayerGui
            .UI.HUD.Gamemodes[trialName].Main.Wave.Value.ContentText
    end)
    if not ok or not result then return 0 end
    local current = tonumber(result:match("^%s*(%d+)"))
    return current or 0
end

local function getNearestTrialEnemy(trialName)
    local folder = getTrialFolder(trialName)
    if not folder then return nil end
    local hrp = _G.GetRoot()
    if not hrp then return nil end
    local hrpPos   = hrp.Position
    local best     = nil
    local bestDist = math.huge
    for _, enemy in pairs(folder:GetChildren()) do
        local pos = getEnemyPosition(enemy)
        if not pos then continue end
        local dist = (hrpPos - pos).Magnitude
        if dist < bestDist then
            bestDist = dist
            best     = enemy
        end
    end
    return best
end

local function getNearestTrialEnemyAlive(trialName)
    local folder = getTrialFolder(trialName)
    if not folder then return nil end
    local hrp = _G.GetRoot()
    if not hrp then return nil end
    local hrpPos   = hrp.Position
    local best     = nil
    local bestDist = math.huge
    for _, enemy in pairs(folder:GetChildren()) do
        if not isEnemyAlive(enemy) then continue end
        local pos = getEnemyPosition(enemy)
        if not pos then continue end
        local dist = (hrpPos - pos).Magnitude
        if dist < bestDist then
            bestDist = dist
            best     = enemy
        end
    end
    return best
end

