if not game:IsLoaded() then
    game.Loaded:Wait()
end

if game.PlaceId ~= 95630541662383 then
    return
end

local redzlib = loadstring(game:HttpGet("https://raw.githubusercontent.com/Absolbite/Library/refs/heads/main/V6-Section", true))()

local Window = redzlib:MakeWindow({
    Name = "World Fighters",
    SubTitle = "ScriptBlox: ChDrago",
    SaveFolder = "WorldFighters"
})

Window:AddTag({
    "Version 1.0.1 [Beta]",
})

Window:AddMinimizeButton({
    Flag = "min_btn",
    Size = 35,
    Transparency = 0,
    Image = "rbxassetid://10734895698",
    Corner = { CornerRadius = UDim.new(0.5, 0) },
    Position = UDim2.fromScale(0.05, 0.5),
})

local Players     = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RS          = game:GetService("ReplicatedStorage")

_G.GetRoot = function()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

_G.GetHumanoid = function()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

_G.Window = Window

_G.Key    = "\002"
_G.NumberOne = 3
_G.NumberTwo = 4
_G.NumberFour = 5

local function fireRemote(args)
    pcall(function()
        RS:WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent"):FireServer(unpack(args))
    end)
end

_G.DiscordTab = Window:MakeTab({ Title = "》Discord《" })
_G.StatusTab = Window:MakeTab({ Title = "》Status《" })
_G.MainTab  = Window:MakeTab({ Title = "》Main《" })
_G.EnemyTab = Window:MakeTab({ Title = "》Enemy《" })
_G.StarsTab = Window:MakeTab({ Title = "》Stars《" })
_G.MiscTab  = Window:MakeTab({ Title = "》Misc《" })
_G.SettingsTab   = Window:MakeTab({ Title = "》Settings《" })

local function loadModule(url)
    pcall(function()
        loadstring(game:HttpGet(url))()
    end)
end

task.spawn(function()

    local base = "https://raw.githubusercontent.com/Absolbite/Scripts/refs/heads/main/"

    local modules = {
        "WF",
    }

    for _, name in ipairs(modules) do
        loadModule(base .. name)
    end

end)

Window:Dialog({
    Title = "Welcome!",
    Text = "World Fighters script loaded successfully!",
    Options = {
        {"OK", function() end}
    }
})
