        for _, star in pairs(starsFolder:GetChildren()) do
            local name = star.Name
            if not table.find(list, name) then
                table.insert(list, name)
            end
        end
    end
    table.sort(list)
    return #list > 0 and list or {"No Stars Found"}
end

local function getStarInstance(selectedName)
    local starsFolder = workspace:FindFirstChild("Server")
        and workspace.Server:FindFirstChild("Stars")
    if starsFolder then
        return starsFolder:FindFirstChild(selectedName)
    end
    return nil
end

local function teleportToStar(starInst)
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp or not starInst then return end

    local cf
    if starInst:IsA("Model") then
        cf = starInst:GetPivot()
    elseif starInst:IsA("BasePart") then
        cf = starInst.CFrame
    else
        return
    end

    local starPos = cf.Position
    local lookVec = cf.LookVector
    local offset  = lookVec * 4 + Vector3.new(0, 10, 0)
    local spawnPos = starPos + offset

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {character}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(spawnPos, Vector3.new(0, -20, 0), rayParams)
    local groundY = result and (result.Position.Y + 3) or (starPos.Y + 3)
    local finalPos = Vector3.new(spawnPos.X, groundY, spawnPos.Z)

    hrp.CFrame = CFrame.new(finalPos, Vector3.new(starPos.X, finalPos.Y, starPos.Z))
end

