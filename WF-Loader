local DIFFICULTY_RANK = {
    Easy   = 1,
    Medium = 2,
    Hard   = 3,
    Insane = 4,
    Boss   = 5,
}

local function getWorldsFolder()
    return workspace:FindFirstChild("Server")
        and workspace.Server:FindFirstChild("Enemies")
        and workspace.Server.Enemies:FindFirstChild("World")
end

local function getGamemodesFolder()
    return workspace:FindFirstChild("Server")
        and workspace.Server:FindFirstChild("Enemies")
        and workspace.Server.Enemies:FindFirstChild("Gamemodes")
end

local function getWorldsList()
    local folder = getWorldsFolder()
    if not folder then return {"No Worlds Found"} end
    local list = {}
    for _, child in pairs(folder:GetChildren()) do
        table.insert(list, child.Name)
    end
    table.sort(list)
    return #list > 0 and list or {"No Worlds Found"}
end

local function getLocationsList(worldName)
    local folder = getWorldsFolder()
    if not folder or not worldName then return {"No Locations Found"} end
    local worldFolder = folder:FindFirstChild(worldName)
    if not worldFolder then return {"No Locations Found"} end
    local list = {}
    for _, child in pairs(worldFolder:GetChildren()) do
        table.insert(list, child.Name)
    end
    table.sort(list)
    return #list > 0 and list or {"No Locations Found"}
end

local function getEnemiesList(worldName, locationName)
    local folder = getWorldsFolder()
    if not folder or not worldName or not locationName then return {"No Enemies Found"} end
    local locFolder = folder:FindFirstChild(worldName)
        and folder[worldName]:FindFirstChild(locationName)
    if not locFolder then return {"No Enemies Found"} end
    local list = {}
    local seen = {}
    for _, enemy in pairs(locFolder:GetChildren()) do
        local name = enemy.Name
        if not seen[name] then
            seen[name] = true
            table.insert(list, name)
        end
    end
    table.sort(list)
    return #list > 0 and list or {"No Enemies Found"}
end

local function isEnemyAlive(enemy)
    return enemy:GetAttribute("Died") ~= true
end

local function getEnemyPosition(enemy)
    if enemy:IsA("BasePart") then
        return enemy.Position
    elseif enemy:IsA("Model") then
        local hrp = enemy:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.Position end
        local pp = enemy.PrimaryPart
        if pp then return pp.Position end
    end
    return nil
end

_G.GetTargetEnemy = function()
    local folder = getWorldsFolder()
    if not folder or not _G.SelectedWorld or not _G.SelectedLocation then return nil end
    local locFolder = folder:FindFirstChild(_G.SelectedWorld)
        and folder[_G.SelectedWorld]:FindFirstChild(_G.SelectedLocation)
    if not locFolder then return nil end
    local hrp = _G.GetRoot()
    if not hrp then return nil end
    local hrpPos   = hrp.Position
    local best     = nil
    local bestDist = math.huge
    for _, spawnPoint in pairs(locFolder:GetChildren()) do
        if next(_G.SelectedEnemies) ~= nil and not _G.SelectedEnemies[spawnPoint.Name] then
            continue
        end
        local pos = getEnemyPosition(spawnPoint)
        if not pos then continue end
        local dist = (hrpPos - pos).Magnitude
        if dist < bestDist then
            bestDist = dist
            best     = spawnPoint
        end
    end
    return best
end

_G.GetTargetEnemyAlive = function()
    local folder = getWorldsFolder()
    if not folder or not _G.SelectedWorld or not _G.SelectedLocation then return nil end
    local locFolder = folder:FindFirstChild(_G.SelectedWorld)
        and folder[_G.SelectedWorld]:FindFirstChild(_G.SelectedLocation)
    if not locFolder then return nil end
    local hrp = _G.GetRoot()
    if not hrp then return nil end
    local hrpPos     = hrp.Position
    local candidates = {}
    for _, spawnPoint in pairs(locFolder:GetChildren()) do
        if next(_G.SelectedEnemies) ~= nil and not _G.SelectedEnemies[spawnPoint.Name] then
            continue
        end
        if not isEnemyAlive(spawnPoint) then continue end
        local pos = getEnemyPosition(spawnPoint)
        if not pos then continue end
        local dist       = (hrpPos - pos).Magnitude
        local maxHealth  = spawnPoint:GetAttribute("MaxHealth") or 0
        local difficulty = spawnPoint:GetAttribute("Difficulty") or "Easy"
        local rank       = DIFFICULTY_RANK[difficulty] or 1
        table.insert(candidates, {
            instance  = spawnPoint,
            pos       = pos,
            dist      = dist,
            maxHealth = maxHealth,
            rank      = rank,
        })
    end
    if #candidates == 0 then return nil end
    local priority = _G.SelectedPriority
    if priority == "Nearest" then
        table.sort(candidates, function(a, b) return a.dist < b.dist end)
    elseif priority == "Random" then
        return candidates[math.random(1, #candidates)].instance
    elseif priority == "Weak To Strong" then
        table.sort(candidates, function(a, b) return a.rank < b.rank end)
    elseif priority == "Strong To Weak" then
        table.sort(candidates, function(a, b) return a.rank > b.rank end)
    end
    return candidates[1].instance
end

