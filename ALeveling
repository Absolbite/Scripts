        local framesContainer = questGui.Container.Frame
        local currentRarities = _G.QuestPriority == "Strong To Weak" and RaritiesStrongToWeak or RaritiesWeakToStrong
        
        for _, rarity in ipairs(currentRarities) do
            local rarityFrame = framesContainer:FindFirstChild(rarity)
            if rarityFrame and rarityFrame:FindFirstChild("Unit") then
                local unit = rarityFrame.Unit
                local amountLabel = unit:FindFirstChild("Amount")
                local nameLabel = unit:FindFirstChild("Name")

                if amountLabel and nameLabel then
                    local amountText = amountLabel.ContentText ~= "" and amountLabel.ContentText or amountLabel.Text
                    local mobName = nameLabel.ContentText ~= "" and nameLabel.ContentText or nameLabel.Text
                    
                    if IsQuestIncomplete(amountText) then
                        return mobName
                    end
                end
            end
        end
    end
    return nil
end

