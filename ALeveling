_G.ServersSection:AddButton({
    Title = "Server Hop",
    Callback = function()
        local function ServerHop()
            local PlaceID = game.PlaceId
            local AllIDs = {}
            local foundAnything = ""
            local attempt = 1
            
            local function TPReturner()
                local Site
                if foundAnything == "" then
                    Site = game:GetService("HttpService"):JSONDecode(game:HttpGet(
                        'https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'
                    ))
                else
                    Site = game:GetService("HttpService"):JSONDecode(game:HttpGet(
                        'https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100&cursor=' .. foundAnything
                    ))
                end
                
                if Site and Site.data then
                    for _, v in pairs(Site.data) do
                        if tonumber(v.maxPlayers) > tonumber(v.playing) and v.id ~= game.JobId then
                            game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, v.id, game.Players.LocalPlayer)
                            return true
                        end
                    end
                    
                    foundAnything = Site.nextPageCursor
                end
                return false
            end
            
            while attempt <= 3 do
                if TPReturner() then
                    return
                end
                attempt = attempt + 1
                task.wait(2)
            end
        end
        
        local success, err = pcall(ServerHop)
        if not success then
            warn("Server hop failed:", err)
        end
    end
})

_G.ServersSection:AddButton({
    Title = "Join Small Server",
    Callback = function()
        local function JoinSmallServer()
            local PlaceID = game.PlaceId
            local response = game:GetService("HttpService"):JSONDecode(game:HttpGet(
                'https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'
            ))
            
            if response and response.data then
                local BestServer = nil
                local LowestPlayers = math.huge
                
                for _, server in pairs(response.data) do
                    if server.playing > 0 and server.playing < LowestPlayers and server.id ~= game.JobId then
                        LowestPlayers = server.playing
                        BestServer = server
                    end
                end
                
                if BestServer then
                    game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, BestServer.id, game.Players.LocalPlayer)
                else
                    warn("No suitable server found")
                end
            end
        end
        
        local success, err = pcall(JoinSmallServer)
        if not success then
            warn("Join small server failed:", err)
        end
    end
})

