local function GetWorldFromStar(starName)
    if not starName then return nil end
    local num = string.match(starName, "%d+")
    return num and ("World" .. num) or "World1"
end

local function IsInCorrectWorld(worldName)
    if not worldName then return false end
    local worldFolder = workspace:FindFirstChild(worldName)
    return worldFolder and worldFolder:FindFirstChild("Map") ~= nil
end

_G.GetStarsList = function()
    local starsList = {}
    local starsFolder = workspace:FindFirstChild("Stars")
    if starsFolder then
        for _, star in ipairs(starsFolder:GetChildren()) do
            local starName = star:GetAttribute("star")
            if starName and not table.find(starsList, starName) then
                table.insert(starsList, starName)
            end
        end
    end
    return #starsList > 0 and starsList or {"No Stars Found"}
end

_G.GetStarInstance = function(selectedName)
    local starsFolder = workspace:FindFirstChild("Stars")
    if starsFolder then
        for _, star in ipairs(starsFolder:GetChildren()) do
            if star:GetAttribute("star") == selectedName then
                return star
            end
        end
    end
    return nil
end

local function TeleportToStar(starInst)
    local character = Players.LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp or not starInst then return end

    local cf
    if starInst:IsA("Model") then
        cf = starInst:GetPivot()
    elseif starInst:IsA("BasePart") then
        cf = starInst.CFrame
    else
        return
    end

    local starPos = cf.Position
    local lookVec = cf.LookVector

    local offset = lookVec * 4 + Vector3.new(0, 10, 0)
    local spawnPos = starPos + offset

    local rayOrigin = spawnPos
    local rayDir = Vector3.new(0, -20, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {character}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(rayOrigin, rayDir, rayParams)
    local groundY = result and (result.Position.Y + 3) or (starPos.Y + 3)

    local finalPos = Vector3.new(spawnPos.X, groundY, spawnPos.Z)

    hrp.CFrame = CFrame.new(finalPos, Vector3.new(starPos.X, finalPos.Y, starPos.Z))
end

