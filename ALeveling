_G.GetRoot = function()
    local player = game.Players.LocalPlayer
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function parseHPValue(mob)
    local val = 0
    pcall(function()
        local hpLabel = mob.Head.BillboardGui.Holder.Health.Bar.HP
        local text = hpLabel.ContentText ~= "" and hpLabel.ContentText or hpLabel.Text
        local raw = string.split(text, "|")[1]
        if raw then
            local num = tonumber(string.match(raw, "[%d%.]+")) or 0
            local suffix = string.match(raw, "%a+")
            val = (suffix and suffixMultipliers[suffix]) and (num * suffixMultipliers[suffix]) or num
        end
    end)
    return val
end

local function isEnemyAlive(mob)
    if not mob or not mob.Parent or mob:GetAttribute("Attackable") == false then return false end
    return parseHPValue(mob) > 0
end

_G.GetEnemiesList = function(worldName)
    local list = {}
    local hash = {}
    local world = workspace:FindFirstChild(worldName)
    if world and world:FindFirstChild("Enemy") then
        for _, mob in pairs(world.Enemy:GetChildren()) do
            if mob:IsA("Model") and not hash[mob.Name] then
                table.insert(list, mob.Name)
                hash[mob.Name] = true
            end
        end
    end
    return list
end

local function selectTarget(targets, priority)
    if #targets == 0 then return nil end
    if priority == "Nearest" then
        table.sort(targets, function(a, b) return a.Distance < b.Distance end)
        return targets[1]
    elseif priority == "Random" then
        return targets[math.random(1, #targets)]
    elseif priority == "Weak To Strong" then
        table.sort(targets, function(a, b) return a.HP < b.HP end)
        return targets[1]
    elseif priority == "Strong To Weak" then
        table.sort(targets, function(a, b) return a.HP > b.HP end)
        return targets[1]
    end
    return targets[1]
end

_G.createWorldAutoTPLoop = function(flagFunc)
    task.spawn(function()
        while flagFunc() do
            if not _G.IsInWorld(_G.SelectedWorld) then
                task.wait(1)
                continue
            end

            local hrp = _G.GetRoot()
            local world = workspace:FindFirstChild(_G.SelectedWorld)
            local enemyFolder = world and world:FindFirstChild("Enemy")

            if not hrp or not enemyFolder then task.wait(); continue end

            local targets = {}
            for _, mob in pairs(enemyFolder:GetChildren()) do
                local isSelected = _G.SelectedEnemies[mob.Name] == true
                    or (type(_G.SelectedEnemies) == "table" and table.find(_G.SelectedEnemies, mob.Name))
                if mob:IsA("Model") and isSelected and isEnemyAlive(mob) then
                    local tHrp = mob:FindFirstChild("HumanoidRootPart")
                    if tHrp then
                        table.insert(targets, {
                            Instance = mob,
                            HRP      = tHrp,
                            Distance = (hrp.Position - tHrp.Position).Magnitude,
                            HP       = parseHPValue(mob)
                        })
                    end
                end
            end

            local targetData = selectTarget(targets, _G.SelectedPriority)

            if targetData then
                local mob = targetData.Instance
                while flagFunc() and mob.Parent and isEnemyAlive(mob) do
                    if not _G.IsInWorld(_G.SelectedWorld) then break end
                    local curHrp = _G.GetRoot()
                    if curHrp and mob:FindFirstChild("HumanoidRootPart") then
                        pcall(function() curHrp.CFrame = mob.HumanoidRootPart.CFrame end)
                    end
                    task.wait()
                end
            else
                task.wait(0)
            end
        end
    end)
end

