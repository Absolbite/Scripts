            if not _G.IsInWorld(worldName) then
                task.wait(1)
                continue
            end

            local hrp = _G.GetRoot()
            local world = workspace:FindFirstChild(worldName)
            local enemyFolder = world and world:FindFirstChild("Enemy")

            if not hrp or not enemyFolder then task.wait(); continue end

            local selectedEnemies = _G.V2.SelectedEnemies[worldName] or {}
            local priority        = _G.V2.GlobalPriority

            local targets = {}
            for _, mob in pairs(enemyFolder:GetChildren()) do
                local isSelected = selectedEnemies[mob.Name] == true
                    or (type(selectedEnemies) == "table" and table.find(selectedEnemies, mob.Name))
                if mob:IsA("Model") and isSelected and isEnemyAlive(mob) then
                    local tHrp = mob:FindFirstChild("HumanoidRootPart")
                    if tHrp then
                        table.insert(targets, {
                            Instance = mob,
                            HRP      = tHrp,
                            Distance = (hrp.Position - tHrp.Position).Magnitude,
                            HP       = parseHPValue(mob)
                        })
                    end
                end
            end

            local targetData = selectTarget(targets, priority)

            if targetData then
                local mob = targetData.Instance
                while _G.V2.AutoTP[worldName] and mob.Parent and isEnemyAlive(mob) do
                    if not _G.IsInWorld(worldName) then break end
                    local curHrp = _G.GetRoot()
                    if curHrp and mob:FindFirstChild("HumanoidRootPart") then
                        pcall(function() curHrp.CFrame = mob.HumanoidRootPart.CFrame end)
                    end
                    task.wait()
                end
            else
                task.wait(0)
            end
        end
    end)
end

