local function parseMultiplier(text)
    if not text then return 0 end
    
    local cleanText = string.gsub(string.lower(text), "x", "")
    cleanText = string.gsub(cleanText, "%s+", "")
    
    local multipliers = {
        k = 10^3,
        m = 10^6,
        b = 10^9,
        t = 10^12
    }
    
    local suffix = string.sub(cleanText, -1)
    local numberValue = tonumber(string.sub(cleanText, 1, -2))
    
    if multipliers[suffix] and numberValue then
        return numberValue * multipliers[suffix]
    end
    
    return tonumber(cleanText) or 0
end

local function deleteLowMultiplierPets()
    local player = game.Players.LocalPlayer
    local championsFolder = player.PlayerGui.Main.Frames.PetInventory.MainFrame:FindFirstChild("Champions")
    
    if not championsFolder then return end
    
    local petsToDelete = {}
    
    for _, pet in pairs(championsFolder:GetChildren()) do
        if pet:IsA("Frame") or pet:IsA("ImageLabel") or pet:IsA("GuiObject") then
            local petNameLabel = pet:FindFirstChild("PetName")
            if petNameLabel then
                local mText = petNameLabel:FindFirstChildOfClass("TextLabel") and petNameLabel.ContentText or petNameLabel.Text
                local currentVal = parseMultiplier(mText)
                
                if currentVal < _G.TargetMultiplier then
                    table.insert(petsToDelete, pet.Name)
                end
            end
        end
    end
    
    if #petsToDelete > 0 then
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Pets"):WaitForChild("DeletePets"):FireServer(petsToDelete)
        end)
    end
end

