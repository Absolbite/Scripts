local function isInRaid()
    local ok, result = pcall(function()
        local waveFrame = game:GetService("Players").LocalPlayer.PlayerGui.Main.HUD.Dungeon.RaidsInfo.WavesFrame.Wave
        local text = waveFrame.ContentText
        if not text or text == "" then
            text = waveFrame.Text or "0/0"
        end
        local cur, max = text:match("^(%d+)/(%d+)$")
        cur = tonumber(cur) or 0
        max = tonumber(max) or 0
        return max > 0
    end)
    return ok and result
end

