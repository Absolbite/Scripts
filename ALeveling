local function IsQuestIncomplete(amountText)
    if not amountText or amountText == "" then return false end
    if string.find(amountText, "/") then
        local parts = string.split(amountText, "/")
        local current = tonumber(string.match(parts[1], "%d+")) or 0
        local max = tonumber(string.match(parts[2], "%d+")) or 0
        return current < max
    end
    return false
end

local function GetActiveQuestMob(worldName)
