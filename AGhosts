local function getStarList()
    local names = {}
    local mapFolder = workspace:FindFirstChild("_MAP")
    if not mapFolder then return names end

    local seen = {}
    for _, worldFolder in pairs(mapFolder:GetChildren()) do
        local eggsFolder = worldFolder:FindFirstChild("Eggs")
        if eggsFolder then
            for _, egg in pairs(eggsFolder:GetChildren()) do
                if not seen[egg.Name] then
                    seen[egg.Name] = true
                    table.insert(names, egg.Name)
                end
            end
        end
    end

    return names
end

local function findStarModel()
    local mapFolder = workspace:FindFirstChild("_MAP")
    if not mapFolder then return nil end

    for _, worldFolder in pairs(mapFolder:GetChildren()) do
        local eggsFolder = worldFolder:FindFirstChild("Eggs")
        if eggsFolder then
            local star = eggsFolder:FindFirstChild(_G.SelectedStar)
            if star then return star end
        end
    end

    return nil
end

