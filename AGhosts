-- ===================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====================
local function getRoot()
    local char = game:GetService("Players").LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getClientFolder()
    local e = workspace:FindFirstChild("_ENEMIES")
    return e and e:FindFirstChild("Client")
end

local function getEnemyDisplayName(enemyModel)
    local billboard = enemyModel:FindFirstChild("EnemyBillboard")
    if billboard then
        local title = billboard:FindFirstChild("Title")
        if title then
            return title.ContentText or title.Text
        end
    end
    return nil
end

local function getEnemyHp(enemyModel)
    if not enemyModel or not enemyModel.Parent then return 0 end
    local billboard = enemyModel:FindFirstChild("EnemyBillboard")
    if not billboard then return 0 end
    local amount = billboard:FindFirstChild("Amount")
    if not amount then return 0 end

    local text = amount.ContentText or amount.Text or ""

    local numStr, suffix = text:match("([%d%.,]+)%s*([%a]*)%s*[Hh][Pp]")
    if not numStr then return 0 end

    numStr = numStr:gsub(",", "")
    local num = tonumber(numStr) or 0

    local suffixes = {
        ["K"]  = 1e3,
        ["M"]  = 1e6,
        ["B"]  = 1e9,
        ["T"]  = 1e12,
        ["QA"] = 1e15,  -- Quadrillion
        ["QI"] = 1e18,  -- Quintillion
        ["SX"] = 1e21,  -- Sextillion
        ["SP"] = 1e24,  -- Septillion
        ["OC"] = 1e27,  -- Octillion
        ["NV"] = 1e30,  -- Nonillion
        ["DC"] = 1e33,  -- Decillion
        -- Старые алиасы на случай если встретятся
        ["QD"] = 1e15,
        ["QN"] = 1e18,
    }

    local mult = suffixes[suffix:upper()]
    if mult then
        num = num * mult
    end

    return num
end

local function isEnemyAlive(enemyModel)
    if not enemyModel or not enemyModel.Parent then return false end
    return getEnemyHp(enemyModel) > 0
end

local function getEnemyRoot(enemyModel)
    return enemyModel:FindFirstChild("HumanoidRootPart")
        or enemyModel:FindFirstChild("RootPart")
        or enemyModel:FindFirstChild("EnemyHitbox")
        or enemyModel.PrimaryPart
end

local function tpToEnemy(hrp, root)
    pcall(function()
        -- Raycast вниз от позиции врага чтобы найти землю
        local rayOrigin = root.Position
        local rayDir = Vector3.new(0, -100, 0)
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {
            game:GetService("Players").LocalPlayer.Character,
            workspace:FindFirstChild("_ENEMIES")
        }
        rayParams.FilterType = Enum.RaycastFilterType.Exclude

        local result = workspace:Raycast(rayOrigin, rayDir, rayParams)
        local groundY = result and (result.Position.Y + 3) or (root.Position.Y - root.Size.Y / 2 + 3)

        hrp.CFrame = CFrame.new(root.Position.X, groundY, root.Position.Z)
    end)
end

local function getEnemyList()
    local names = {}
    local clientFolder = getClientFolder()
    if not clientFolder then return names end
    local seen = {}
    for _, enemyModel in pairs(clientFolder:GetChildren()) do
        if enemyModel:IsA("Model") then
            local name = getEnemyDisplayName(enemyModel)
            if name and name ~= "" and not seen[name] then
                seen[name] = true
                table.insert(names, name)
            end
        end
    end
    return names
end

local function findTargetEnemy()
    local hrp = getRoot()
    if not hrp then return nil end
    local clientFolder = getClientFolder()
    if not clientFolder then return nil end

    local selectedSet = {}
    for _, name in pairs(_G.SelectedEnemies) do
        selectedSet[name] = true
    end

    local bestModel = nil
    local bestDist = math.huge

    for _, enemyModel in pairs(clientFolder:GetChildren()) do
        if enemyModel:IsA("Model") then
            local enemyName = getEnemyDisplayName(enemyModel)
            if enemyName and selectedSet[enemyName] and isEnemyAlive(enemyModel) then
                local root = getEnemyRoot(enemyModel)
                if root then
                    local dist = (root.Position - hrp.Position).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestModel = enemyModel
                    end
                end
            end
        end
    end

    return bestModel
end

