local function getClosestEnemyId()
    local player = game:GetService("Players").LocalPlayer
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = character.HumanoidRootPart

    local clientFolder = workspace:FindFirstChild("_ENEMIES")
        and workspace._ENEMIES:FindFirstChild("Client")
    if not clientFolder then return nil end

    local closestId = nil
    local closestDist = math.huge

    for _, enemyModel in ipairs(clientFolder:GetChildren()) do
        local hitbox = enemyModel:FindFirstChild("EnemyHitbox")
        if hitbox then
            local dist = (hitbox.Position - hrp.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestId = enemyModel.Name -- "58ab7098511e4213a8ac873a33cf176c"
            end
        end
    end

    return closestId
end

