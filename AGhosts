                                if dist < bestDist then
                                    bestDist = dist
                                    bestModel = enemyModel
                                end
                            end
                        end
                    end

                    if bestModel then
                        while _G.AutoTpNearestEnabled and isEnemyAlive(bestModel) do
                            hrp = getRoot()
                            local root = getEnemyRoot(bestModel)
                            if hrp and root then
                                tpToEnemy(hrp, root)
                            end
                            task.wait()
                        end
                        task.wait(0)
                    else
                        task.wait(0)
                    end
                end
            end)
        end
    end
})

